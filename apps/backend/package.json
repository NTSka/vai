{
  "name": "@vai/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build && node --env-file-if-exists=.env --enable-source-maps dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "health:check": "pnpm build && node --enable-source-maps dist/cli/health-check.js",
    "test": "vitest run",
    "lint": "echo \"backend lint is not configured yet\"",
    "format": "echo \"backend format is not configured yet\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@fastify/swagger": "^9.5.2",
    "fastify": "^5.6.2",
    "fastify-type-provider-zod": "^5.1.0",
    "drizzle-orm": "^0.44.7",
    "pg": "^8.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.7",
    "vitest": "^3.2.4"
  }
}
